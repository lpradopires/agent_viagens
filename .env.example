# Chave de Autenticação da GeckoAPI (MCP)
GECKO_API_KEY=sua_chave_da_geckoapi_aqui

# Chave de Autenticação da Google Gemini API (Google AI Studio)
GEMINI_API_KEY=sua_chave_do_google_ai_studio_aqui

# Chave de Autenticação da Groq API (Alternativa gratuita)
GROQ_API_KEY=sua_chave_da_groq_aqui

# Chave de Autenticação do OpenRouter (LLM Gratuito Ilimitado)
OPENROUTER_API_KEY=sua_chave_do_openrouter_aqui

# Chave de Autenticação Oficial da OpenAI (Modelo gpt-4.1-nano)
OPENAI_API_KEY=sua_chave_openai_aqui

# Porta opcional se o serviço for convertido em API futuramente
PORT=3000

# Provedor de API de viagens (GeckoAPI ou Duffel)
TRAVEL_API_PROVIDER=GeckoAPI

# Chave de Acesso para Duffel API (Flights e Stays)
DUFFEL_ACCESS_TOKEN=sua_chave_duffel_aqui
